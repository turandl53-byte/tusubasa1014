from flask import Flask, render_template, request, jsonify
from datetime import datetime, timedelta
import os
from werkzeug.utils import secure_filename
import random
import threading
import time

BASE_DIR = os.path.dirname(os.path.abspath(__file__))

app = Flask(__name__, template_folder=os.path.join(BASE_DIR, 'templates'), 
            static_folder=os.path.join(BASE_DIR, 'static'),
            static_url_path='/static')
app.config['MAX_CONTENT_LENGTH'] = 200 * 1024 * 1024
app.config['SEND_FILE_MAX_AGE_DEFAULT'] = 0

ADMIN_SIFRE = "12345"

RESIM_KLASOR = os.path.join(BASE_DIR, 'static', 'resimler')
VIDEO_KLASOR = os.path.join(BASE_DIR, 'static', 'videolar')

os.makedirs(RESIM_KLASOR, exist_ok=True)
os.makedirs(VIDEO_KLASOR, exist_ok=True)

mesajlar = []

@app.route('/')
def ana_sayfa():
    return render_template('index.html')

@app.route('/gonder', methods=['POST'])
def mesaj_gonder():
    sifre = request.form.get('sifre', '')
    if sifre != ADMIN_SIFRE:
        return jsonify({'durum': 'hata', 'mesaj': 'Şifre yanlış!'}), 403
    
    kullanici = request.form.get('kullanici', 'Anonim')
    icerik = request.form.get('icerik', '')
    resim = request.files.get('resim')
    video = request.files.get('video')
    
    resim_yolu = None
    video_yolu = None
    
    if resim and resim.filename:
        ad = str(int(time.time())) + '_' + secure_filename(resim.filename)
        resim.save(os.path.join(RESIM_KLASOR, ad))
        resim_yolu = '/static/resimler/' + ad
    
    if video and video.filename:
        ad = str(int(time.time())) + '_' + secure_filename(video.filename)
        video.save(os.path.join(VIDEO_KLASOR, ad))
        video_yolu = '/static/videolar/' + ad
    
    mesaj = {
        'kullanici': kullanici,
        'icerik': icerik,
        'resim': resim_yolu,
        'video': video_yolu,
        'zaman': datetime.now().strftime('%H:%M · %d.%m.%Y'),
        'begeni': 0,
        'yorum': 0,
        'retweet': 0,
        'goruntulenme': 0
    }
    
    mesajlar.insert(0, mesaj)
    if len(mesajlar) > 100:
        mesajlar.pop()
    
    return jsonify({'durum': 'basarili'})

@app.route('/mesajlar')
def mesajlari_getir():
    return jsonify(mesajlar)

@app.after_request
def no_cache(response):
    response.headers['Cache-Control'] = 'no-store, no-cache, must-revalidate, max-age=0'
    response.headers['Pragma'] = 'no-cache'
    response.headers['Expires'] = '0'
    return response

