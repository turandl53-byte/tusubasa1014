def rastgele_zaman():
    """Son 6 saat içinde rastgele bir zaman döndür"""
    su_an = datetime.now()
    dakika_once = random.randint(1, SAHTE_TWEET_GECMIS_SAAT * 60)
    tweet_zamani = su_an - timedelta(minutes=dakika_once)
    return tweet_zamani.strftime('%H:%M · %d.%m.%Y')

def sahte_tweet_olustur():
    return {
        'kullanici': random.choice(sahte_kullanicilar),
        'icerik': random.choice(sahte_icerikler),
        'resim': None,
        'video': None,
        'zaman': rastgele_zaman(),
        'begeni': random.randint(0, 500),
        'yorum': random.randint(0, 100),
        'retweet': random.randint(0, 200),
        'goruntulenme': random.randint(100, 10000)
    }

# Başlangıçta sahte tweetleri ekle
for _ in range(SAHTE_TWEET_BASLANGIC):
    mesajlar.append(sahte_tweet_olustur())

def surekli_sahte_tweet():
    while True:
        # Rastgele aralıkta bekle (1-3 dakika arası)
        bekleme_suresi = random.randint(SAHTE_TWEET_ARALIK_MIN, SAHTE_TWEET_ARALIK_MAX)
        time.sleep(bekleme_suresi)
        
        # Yeni sahte tweet ekle
        mesajlar.insert(0, sahte_tweet_olustur())
        
        # Listeyi 100 ile sınırla
        if len(mesajlar) > 100:
            mesajlar.pop()
        
        print(f"Sahte tweet eklendi - {datetime.now().strftime('%H:%M:%S')} (Sıradaki: {bekleme_suresi}s sonra)")

threading.Thread(target=surekli_sahte_tweet, daemon=True).start()

